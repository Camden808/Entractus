// Prisma schema for the Entractus API.
// Field names use camelCase in Prisma; @map keeps DB columns snake_case
// to match the naming used in Requirements.md and Tasks.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin

  @@map("user_role")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  company      String?
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  timezone     String   @default("UTC")
  role         UserRole @default(user)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  industries           Industry[]
  jobPostings          JobPosting[]
  revokedRefreshTokens RevokedRefreshToken[]
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model EmployerRequest {
  id                 String   @id @default(uuid()) @db.Uuid
  firstName          String   @map("first_name")
  lastName           String   @map("last_name")
  company            String
  addressLine1       String   @map("address_line_1")
  addressLine2       String?  @map("address_line_2")
  city               String?
  state              String?
  phone              String
  email              String
  positionName       String?  @map("position_name")
  positionTitle      String?  @map("position_title")
  positionType       String?  @map("position_type")
  hours              String?
  duties             String?
  referralSource     String?  @map("referral_source")
  questions          String?
  jobDescriptionPath String?  @map("job_description_path")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("employer_requests")
}

model Industry {
  id     String  @id @default(uuid()) @db.Uuid
  userId String? @map("user_id") @db.Uuid
  name   String
  client Boolean @default(false)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("industries")
}

// Single-use password reset tokens. We store the SHA-256 hash of the
// raw token (which is what's emailed to the user); the raw token never
// touches the DB. usedAt being non-null prevents replay.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Refresh-token revocation list. Any jti added here is rejected by
// POST /api/auth/refresh. Rows are pruneable once their `expiresAt`
// passes (cleanup is a future cron task).
model RevokedRefreshToken {
  jti       String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime @default(now()) @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("revoked_refresh_tokens")
}

model JobPosting {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  state       String
  city        String
  type        String
  company     String
  postedDate  DateTime @default(now()) @map("posted_date")
  description String
  createdById String   @map("created_by") @db.Uuid

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([city])
  @@index([type])
  @@index([company])
  @@map("job_postings")
}

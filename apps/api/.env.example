# --- API server ---
PORT=3001
NODE_ENV=development

# Origin allowed by CORS (your web app)
WEB_ORIGIN=http://localhost:5173

# Base URL used to build links in emails (e.g. password-reset). Defaults to
# WEB_ORIGIN when unset.
WEB_BASE_URL=http://localhost:5173

# --- Database ---
# Local Postgres via docker-compose (see top-level README)
DATABASE_URL=postgresql://entractus:entractus@localhost:5432/entractus?schema=public

# --- Auth (JWT) ---
# Use long, random strings in production. Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Single-use password-reset token lifetime. Defaults to 1h.
PASSWORD_RESET_TTL=1h

# --- SMTP / Mail ---
# In dev, Nodemailer + Ethereal works without these. In production, the mailer
# falls back to log-only until SMTP_HOST/USER/PASS are set (see §16).
SMTP_HOST=
SMTP_PORT=587
# Set to "true" for implicit TLS (port 465); otherwise STARTTLS on 587.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Entractus Recruitment <no-reply@entractus.local>"
# Internal recipient for employer-request notifications. Defaults to
# contact@entractus.com.
EMPLOYER_NOTIFY_TO=contact@entractus.com

# --- File uploads ---
# Local filesystem path for employer job-description uploads in dev.
UPLOAD_DIR=./uploads

{
  "name": "entractus-recruitment",
  "version": "0.1.0",
  "private": true,
  "description": "Entractus Recruitment website monorepo (web + api).",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "db:studio": "npm --workspace apps/api run db:studio",
    "lint": "npm --workspaces --if-present run lint",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:api": "npm --workspace apps/api run lint",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "typecheck:api": "npm --workspace apps/api run typecheck",
    "test": "npm --workspaces --if-present run test",
    "test:web": "npm --workspace apps/web run test",
    "test:api": "npm --workspace apps/api run test",
    "test:coverage": "npm --workspaces --if-present run test:coverage",
    "format": "prettier --write \".\"",
    "format:check": "prettier --check \".\""
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
